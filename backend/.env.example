TYPEDB_ADDRESS=https://rp78xj-0.cluster.typedb.com:80
TYPEDB_DATABASE=unigran_db
TYPEDB_USERNAME=admin
TYPEDB_PASSWORD=sua_senha_aqui

# Seed do Portal Academico: usado somente para criar contas que ainda nao existem.
# Os dois professores podem usar senhas especificas; nao commite senhas reais.
SEED_DEFAULT_PASSWORD=
SEED_GABRIELAOZOIO_PASSWORD=
SEED_VITTONLIMA_PASSWORD=

JWT_SECRET=troque_este_segredo
JWT_EXPIRES_IN=7d

PORT=3001
NODE_ENV=development
CLIENT_URL=http://localhost:5173
PUBLIC_APP_URL=http://localhost:5173
PUBLIC_PORTFOLIO_BASE_URL=http://localhost:5173

CLOUDINARY_CLOUD_NAME=demo
CLOUDINARY_API_KEY=123456789012345
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Documentos do AVA, principalmente entregas academicas
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key
SUPABASE_DOCUMENTS_BUCKET=ava-entregas
ABLY_API_KEY=your_ably_root_api_key

# Email para codigo de redefinicao de senha. Gmail: use senha de app.
EMAIL_USER=seu_email@gmail.com
EMAIL_PASS=sua_senha_de_app
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false

JIGSAWSTACK_API_KEY=your_jigsawstack_api_key
JIGSAWSTACK_NSFW_THRESHOLD=0.72

# RAi: Groq usa a API OpenAI-compatible. Sem chave, o RAi retorna somente fatos verificados do portal.
RAI_AI_API_KEY=
RAI_AI_API_URL=https://api.groq.com/openai/v1/chat/completions
RAI_AI_MODEL=llama-3.3-70b-versatile
RAI_AI_TIMEOUT_MS=20000

# Pesquisa publica opcional do RAi via Tavily Search API.
RAI_WEB_SEARCH_ENABLED=false
TAVILY_API_KEY=
RAI_WEB_SEARCH_TIMEOUT_MS=10000

# Artefatos ML grandes mantidos fora do Git
ML_OUTPUTS_DRIVE_URL=https://drive.google.com/drive/folders/1Rs2dtpA3fDlCQ2hoih_DeMK45TbV5gWS?usp=sharing
ML_MODELS_DRIVE_URL=https://drive.google.com/drive/folders/1wLoxMCGMYMgadi6N2BEJP9HAegpi78yd?usp=sharing

# Supabase Storage (somente arquivos)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Auditoria SQL legada/opcional. Mantenha vazio se TypeDB for a unica escrita.
AUDIT_DATABASE_URL=
# Fallback de auditoria em arquivo. Na Vercel usa /tmp por padrao.
AUDIT_LOG_DIR=

# Alternativa SQL antiga; deixe vazia na arquitetura TypeDB + Storage.
DB_HOST=
DB_PORT=5432
DB_NAME=postgres
DB_USER=
DB_PASSWORD=

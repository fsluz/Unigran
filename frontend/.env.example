VITE_API_URL=https://unigran-backend.vercel.app/api
VITE_GOOGLE_CLIENT_ID=seu_client_id_google.apps.googleusercontent.com

# GPT Maker Chat Integration
# Get your chatbot ID from: https://app.gptmaker.ai/dashboard/integrations/
# Example: VITE_GPTMAKER_CHATBOT_ID=abc123def456
VITE_GPTMAKER_CHATBOT_ID=YOUR_CHATBOT_ID

# Feature Flags
VITE_ENABLE_RAI=true
VITE_ENABLE_GPTMAKER_CHAT=true

